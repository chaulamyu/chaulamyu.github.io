{% comment %}
  Unified services entry renderer for both formats
  - RenderCV uses: name, summary
  - JSONResume uses: services, fluency
{% endcomment %}

<div class="card-text font-weight-light">
  {% for entry in entries %}
    <div class="services-item">
      {% if entry.icon %}
        <i class="{{ entry.icon }}"></i>
      {% endif %}
      {% capture service_name %}
        {% if entry.name %}{{ entry.name }}{% elsif entry.services %}{{ entry.services }}{% endif %}
      {% endcapture %}
      {% capture fluency %}
        {% if entry.summary %}{{ entry.summary }}{% elsif entry.fluency %}{{ entry.fluency }}{% endif %}
      {% endcapture %}
      <strong>{{ service_name }}:</strong> {{ fluency }}
    </div>
  {% endfor %}
</div>

<style>
  .services-item {
    padding: 0.5rem 0;
  }
</style>
